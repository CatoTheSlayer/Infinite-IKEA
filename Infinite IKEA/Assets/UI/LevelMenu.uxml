<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/levelMenu.uss?fileID=7433441132597879392&amp;guid=f0323baf9b516ca48ae36d8a66ccb07a&amp;type=3#levelMenu"/>
    <ui:VisualElement style="flex-grow: 1;">
        <ui:VisualElement name="Bagrund" class="bagrund" style="flex-grow: 1; background-color: rgb(255, 255, 255); width: 100%; height: 100%;">
