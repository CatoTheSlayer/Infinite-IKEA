            </ui:VisualElement>
            <ui:VisualElement name="MissionBlock" class="MissionBlock" style="flex-grow: 1; width: 200px; height: 250px; border-left-color: rgb(118, 118, 118); border-right-color: rgb(118, 118, 118); border-top-color: rgb(118, 118, 118); border-bottom-color: rgb(118, 118, 118); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; max-height: 250px; max-width: 200px; top: 20%; left: 65%; background-color: rgba(166, 166, 166, 0.35); position: absolute;">
                <ui:Label text="BOSS" name="MissionTitle" class="MissionBlockTitle" style="font-size: 25px; -unity-text-align: upper-center; -unity-font-definition: url(&quot;project://database/Assets/Skrifttyper/IKEASans-Bold.ttf?fileID=12800000&amp;guid=7f0cdf3d8a0aee746962edc1432aacea&amp;type=3#IKEASans-Bold&quot;); border-left-color: rgb(118, 118, 118); border-right-color: rgb(118, 118, 118); border-top-color: rgb(118, 118, 118); border-bottom-color: rgb(118, 118, 118); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; background-color: rgb(195, 195, 195); flex-direction: row;"/>
